/**
 * 2-server, 2-job system with asymmetric server flexibility.
 * - Server 0: specialist — can only serve job type 0.
 * - Server 1: generalist — can serve both job types.
 * - Symmetric costs and equal arrivals; the routing tension is structural.
 *
 * Key decision: when server 1 (generalist) is free and FIL_0 > FIL_1, FIFO
 * assigns server 1 to type 0.  The optimal policy should reserve server 1 for
 * type 1 (the only server that can serve it) and let the specialist handle type 0.
 *
 * rho_0 = 0.3 / (1.0 + 1.0) = 0.15  (two servers can serve type 0)
 * rho_1 = 0.3 / 1.0          = 0.30  (only server 1 can serve type 1)
 */
{
    "id": "queue_mdp",
    "discount_factor": 1.0,
    "reward_type": 0,
    "k_servers": 2,
    "n_jobs": 2,
    "tick_rate": 1.0,
    "arrival_rates": [ 0.3, 0.3 ],
    "cost_rates":    [ 100.0, 100.0 ],
    "due_times":     [ 6.0, 6.0 ],
    "server_type_0": {
        "servers": 1,
        "can_serve": [ 0 ],
        "service_rates": [ 1.0 ]
    },
    "server_type_1": {
        "servers": 1,
        "can_serve": [ 0, 1 ],
        "service_rates": [ 1.0, 1.0 ]
    }
}
