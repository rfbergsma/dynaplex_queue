/**
 * Experiment 2: Specialist + Generalist with Modest Cost Asymmetry
 *
 * Clean pedagogical example: specialist-generalist skill structure creates
 * routing complexity, with modest cost asymmetry (1.5x) to incentivize
 * optimal routing. Cleaner than Experiment 3's 3x cost ratio.
 *
 * - Server 0 (specialist): serves type 0 only
 * - Server 1 (generalist): serves both types
 * - Type 1 arrives 50% more frequently → overloads generalist server
 * - Type 1 costs 1.5x more (modest asymmetry) → should be prioritized
 * - Equal deadlines (focus on cost-driven routing, not deadline pressure)
 * - Optimal policy: prioritize type 1, load-balance type 0
 * - FIFO follows FIL order regardless of cost → ~15% gap expected
 */
{
    "id": "queue_mdp",
    "discount_factor": 1.0,
    "reward_type": 0,
    "k_servers": 2,
    "n_jobs": 2,
    "tick_rate": 1.0,
    "arrival_rates": [ 0.20, 0.30 ],
    "cost_rates":    [ 100.0, 150.0 ],
    "due_times":     [ 6.0, 6.0 ],
    "server_type_0": {
        "servers": 1,
        "can_serve": [ 0 ],
        "service_rates": [ 0.35 ]
    },
    "server_type_1": {
        "servers": 1,
        "can_serve": [ 0, 1 ],
        "service_rates": [ 0.35, 0.35 ]
    }
}
