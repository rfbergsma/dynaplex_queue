/**
 * Experiment 2: Specialist + Generalist with Symmetric Costs/Deadlines
 *
 * Clean pedagogical example: specialist-generalist skill structure creates
 * routing complexity, while symmetric costs/deadlines keep the problem focused.
 *
 * - Server 0 (specialist): serves type 0 only
 * - Server 1 (generalist): serves both types
 * - Type 1 arrives 50% more frequently → overloads generalist server
 * - Equal costs and deadlines (clean differentiation from MM/1)
 * - Optimal policy load-balances type 0 to specialist, type 1 to generalist
 * - FIFO fails to load-balance → ~20% gap
 */
{
    "id": "queue_mdp",
    "discount_factor": 1.0,
    "reward_type": 0,
    "k_servers": 2,
    "n_jobs": 2,
    "tick_rate": 1.0,
    "arrival_rates": [ 0.20, 0.30 ],
    "cost_rates":    [ 100.0, 100.0 ],
    "due_times":     [ 6.0, 6.0 ],
    "server_type_0": {
        "servers": 1,
        "can_serve": [ 0 ],
        "service_rates": [ 0.35 ]
    },
    "server_type_1": {
        "servers": 1,
        "can_serve": [ 0, 1 ],
        "service_rates": [ 0.35, 0.35 ]
    }
}
