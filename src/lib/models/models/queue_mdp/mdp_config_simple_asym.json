/**
 * Asymmetric 2x2 system — same topology as mdp_config_simple.json but with
 * deliberate asymmetry in arrivals, costs, and deadlines so that the optimal
 * policy differs meaningfully from FIFO (higher Z-score training signal).
 *
 * - Job type 1 arrives more often, costs 3x more, and has a tighter deadline.
 * - rho = (0.15+0.35)/(0.35+0.35) = 0.50/0.70 ~= 0.71 (same as simple).
 * - tick_rate=1.0, fully flexible servers — routing decisions matter here.
 */
{
    "id": "queue_mdp",
    "discount_factor": 1.0,
    "k_servers": 2,
    "n_jobs": 2,
    "tick_rate": 1.0,
    "arrival_rates": [ 0.15, 0.35 ],
    "cost_rates":    [ 100.0, 300.0 ],
    "due_times":     [ 6.0,  3.0  ],
    "server_type_0": {
        "servers": 1,
        "can_serve": [ 0, 1 ],
        "service_rate": 0.35
    },
    "server_type_1": {
        "servers": 1,
        "can_serve": [ 0, 1 ],
        "service_rate": 0.35
    }
}
