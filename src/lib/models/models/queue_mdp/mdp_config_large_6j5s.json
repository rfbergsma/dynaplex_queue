/**
 * Large queue system: 6 job types, 5 server types, chain skill structure.
 *
 * Chain flexibility: server k can serve jobs {k, k+1} only.
 *   server_type_0: jobs {0, 1}
 *   server_type_1: jobs {1, 2}
 *   server_type_2: jobs {2, 3}
 *   server_type_3: jobs {3, 4}
 *   server_type_4: jobs {4, 5}
 *
 * Simple→complex gradient (left to right):
 *   mu:   job 0=1.2, 1=1.1, 2=1.0, 3=0.9, 4=0.8, 5=0.7
 *   cost: job 0= 50, 1= 75, 2=100, 3=125, 4=150, 5=200
 *   D:    job 0=8.0, 1=7.0, 2=6.0, 3=5.0, 4=4.0, 5=3.0
 *
 * End jobs (0 and 5) each have only one server type that can serve them,
 * making routing especially critical near the chain endpoints.
 *
 * Approximate single-server utilisation at endpoints:
 *   rho_0 ~ 0.20 / 1.2 = 0.167  (served only by server_type_0)
 *   rho_5 ~ 0.15 / 0.7 = 0.214  (served only by server_type_4)
 */
{
    "id": "queue_mdp",
    "discount_factor": 1.0,
    "reward_type": 0,
    "k_servers": 5,
    "n_jobs": 6,
    "tick_rate": 1.0,
    "arrival_rates": [ 0.20, 0.20, 0.20, 0.20, 0.20, 0.15 ],
    "cost_rates":    [ 50.0, 75.0, 100.0, 125.0, 150.0, 200.0 ],
    "due_times":     [ 8.0,  7.0,  6.0,   5.0,   4.0,   3.0  ],
    "server_type_0": {
        "servers": 1,
        "can_serve": [ 0, 1 ],
        "service_rates": [ 1.2, 1.1 ]
    },
    "server_type_1": {
        "servers": 1,
        "can_serve": [ 1, 2 ],
        "service_rates": [ 1.1, 1.0 ]
    },
    "server_type_2": {
        "servers": 1,
        "can_serve": [ 2, 3 ],
        "service_rates": [ 1.0, 0.9 ]
    },
    "server_type_3": {
        "servers": 1,
        "can_serve": [ 3, 4 ],
        "service_rates": [ 0.9, 0.8 ]
    },
    "server_type_4": {
        "servers": 1,
        "can_serve": [ 4, 5 ],
        "service_rates": [ 0.8, 0.7 ]
    }
}
